# Variáveis de ambiente — copie este arquivo para .env.local e preencha os valores
# No Vercel: adicione estas variáveis em Settings > Environment Variables

# Supabase — encontre em: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key — NUNCA exponha esta chave no frontend
# Usada apenas em rotas de API server-side (app/api/*)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
